<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="http://marcboyer.com/transitmap"
        version="1.0.0"
        viewmodes="fullscreen">

  <!--
    Replace the package ID (0000000000) with the one assigned by Samsung Sellers Office.
    Required version 3.0 = Tizen 3.0+ (Samsung TVs from 2017 onwards).
  -->
  <tizen:application id="0000000000.transitmap"
                     package="0000000000"
                     required_version="3.0"/>

  <!-- Entry point — generated by build.js from the prototype -->
  <content src="index.html"/>

  <!-- Screen size: accept all TV resolutions (1080p, 4K) -->
  <feature name="http://tizen.org/feature/screen.size.all"/>

  <!-- Internet access for Cloudflare Worker API polling -->
  <tizen:privilege name="http://tizen.org/privilege/internet"/>

  <tizen:setting
    screen-orientation="landscape"
    context-menu="disable"
    background-support="disable"
    encryption="disable"
    install-location="auto"
    hw-key-event="enable"/>

  <icon src="icon.png"/>
  <name>TransitMap</name>
  <description>Live train maps for cities around the world — ambient display for your TV.</description>
</widget>
