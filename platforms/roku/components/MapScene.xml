<?xml version="1.0" encoding="utf-8" ?>
<component name="MapScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/MapScene.brs"/>
  <children>

    <!-- Dark fill shown before map image loads -->
    <Rectangle id="bgFill" width="1920" height="1080" color="0x080C14FF"/>

    <!-- Pre-rendered city map PNG (generated by gen_maps.js) -->
    <Poster id="mapBg" width="1920" height="1080" loadDisplayMode="limitSize"/>

    <!-- Train dots appended here dynamically -->
    <Group id="trainLayer"/>

    <!-- Top-left info panel (city name, train count, local time) — overlay, no background -->
    <Label id="topCityName"
           translation="[80, 80]"
           width="1760"
           font="font:LargeBoldSystemFont"
           color="0xFFFFFFFF"
           text=""/>

    <Label id="topSub"
           translation="[80, 148]"
           width="1760"
           font="font:SmallSystemFont"
           color="0xFFFFFF88"
           text=""/>

    <Label id="topTrains"
           translation="[80, 180]"
           width="1760"
           font="font:SmallSystemFont"
           color="0xFFFFFFCC"
           text=""/>

    <Label id="topTime"
           translation="[80, 212]"
           width="1760"
           font="font:SmallSystemFont"
           color="0xFFFFFF66"
           text=""/>

    <!-- Nav hint (center) -->
    <Label id="navHint"
           translation="[0, 1008]"
           width="1920"
           horizAlign="center"
           font="font:SmallSystemFont"
           color="0xFFFFFF44"
           text="&lt; &gt;  change city"/>

    <!-- Worker version (right of center, logo sits to its right) -->
    <Label id="workerVer"
           translation="[0, 1008]"
           width="1640"
           horizAlign="right"
           font="font:SmallSystemFont"
           color="0xFFFFFF44"
           text=""/>

    <!-- 6-KIDS logo — bottom-right, same line as worker version -->
    <Poster id="logoImg"
            uri="pkg:/images/sixkids_logo.png"
            width="187" height="24"
            translation="[1693, 1004]"
            opacity="0.8"/>

    <!-- Invisible full-screen focus target for key handling -->
    <Rectangle id="focusTrap" width="1920" height="1080" color="0x00000000"/>

  </children>
</component>
