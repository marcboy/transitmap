<?xml version="1.0" encoding="utf-8" ?>
<component name="MapScene" extends="Scene">
  <script type="text/brightscript" uri="pkg:/components/MapScene.brs"/>
  <children>

    <!-- Dark fill shown before map image loads -->
    <Rectangle id="bgFill" width="1920" height="1080" color="0x080C14FF"/>

    <!-- Pre-rendered city map PNG (generated by gen_maps.js) -->
    <Poster id="mapBg" width="1920" height="1080" loadDisplayMode="limitSize"/>

    <!-- Train dots appended here dynamically -->
    <Group id="trainLayer"/>

    <!-- Bottom gradient bar -->
    <Rectangle id="bottomBar" width="1920" height="130"
               translation="[0, 950]" color="0x04080EF0"/>

    <!-- City name (large, bottom-left) -->
    <Label id="cityName"
           translation="[80, 958]"
           font="font:LargeBoldSystemFont"
           color="0xFFFFFFFF"
           text=""/>

    <!-- System + train count (small, below city name) -->
    <Label id="citySub"
           translation="[80, 1008]"
           font="font:SmallSystemFont"
           color="0xFFFFFF99"
           text=""/>

    <!-- Nav hint (center) -->
    <Label id="navHint"
           translation="[0, 1008]"
           width="1920"
           horizAlign="center"
           font="font:SmallSystemFont"
           color="0xFFFFFF44"
           text="&lt; &gt;  change city"/>

    <!-- Worker version (far right) -->
    <Label id="workerVer"
           translation="[0, 1008]"
           width="1840"
           horizAlign="right"
           font="font:SmallSystemFont"
           color="0xFFFFFF44"
           text=""/>

    <!-- 6-KIDS logo — bottom-right, above bottom bar -->
    <Poster id="logoImg"
            uri="pkg:/images/sixkids_logo.png"
            width="390" height="50"
            translation="[1490, 892]"
            opacity="0.8"/>

    <!-- Invisible full-screen focus target for key handling -->
    <Rectangle id="focusTrap" width="1920" height="1080" color="0x00000000"/>

  </children>
</component>
